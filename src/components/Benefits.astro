<section id="benefits" class="bg-slate-50 py-20 px-4 relative overflow-hidden">
    <!-- Decorative Vector Background -->
    <div class="absolute inset-0 overflow-hidden pointer-events-none z-0">
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-gradient-to-tr from-blue-100/40 via-purple-100/20 to-transparent blur-3xl rounded-full opacity-60"></div>
    </div>

    <div class="max-[min(100vw,768px)] max-w-screen-xl mx-auto relative z-10 fade-in-up">
        <div class="text-center mb-16">
            <h2 class="text-3xl font-extrabold text-slate-800 mb-4 tracking-tight">Perbandingan Program</h2>
            <p class="text-subtle font-medium text-lg">Temukan yang paling pas untukmu.</p>
        </div>

        <!-- Desktop View (Table) -->
        <div class="hidden md:block relative overflow-hidden shadow-lg sm:rounded-3xl max-w-4xl mx-auto border border-slate-200 bg-white/80 backdrop-blur-md group hover:shadow-xl transition-shadow duration-500">
            <div class="absolute inset-0 bg-gradient-to-br from-transparent via-slate-50/50 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-700 z-0 pointer-events-none"></div>
            <table class="w-full text-sm text-left text-slate-600 relative z-10">
                <thead class="text-xs text-slate-700 uppercase bg-slate-100/50 border-b border-slate-200">
                    <tr>
                        <th scope="col" class="px-8 py-6 w-1/3 tracking-wider font-extrabold">Fitur</th>
                        <th scope="col" class="px-8 py-6 w-1/3 text-blue-700 tracking-wider font-extrabold">Coding Camp 2026</th>
                        <th scope="col" class="px-8 py-6 w-1/3 text-purple-700 tracking-wider font-extrabold">METC</th>
                    </tr>
                </thead>
                <tbody>
                    <tr class="border-b border-slate-100 hover:bg-blue-50/30 transition-colors duration-300">
                        <th scope="row" class="px-8 py-5 font-bold text-slate-800 whitespace-nowrap">
                            Target Audience
                        </th>
                        <td class="px-8 py-5 font-medium">
                            Mahasiswa, Siswa SMK, Umum
                        </td>
                        <td class="px-8 py-5 font-medium">
                            Tech Professional, Aspiring Talent
                        </td>
                    </tr>
                    <tr class="border-b border-slate-100 hover:bg-blue-50/30 transition-colors duration-300">
                        <th scope="row" class="px-8 py-5 font-bold text-slate-800 whitespace-nowrap">
                            Fokus Utama
                        </th>
                        <td class="px-8 py-5 font-medium">
                            Hard Skills (Web/AI/Data) + Soft Skills
                        </td>
                        <td class="px-8 py-5 font-medium">
                            Microsoft Tech (Cloud, AI)
                        </td>
                    </tr>
                    <tr class="border-b border-slate-100 hover:bg-blue-50/30 transition-colors duration-300">
                        <th scope="row" class="px-8 py-5 font-bold text-slate-800 whitespace-nowrap">
                            Sertifikat
                        </th>
                        <td class="px-8 py-5 font-medium">
                            Sertifikat Kompetensi Dicoding
                        </td>
                        <td class="px-8 py-5 font-medium">
                            Certificate of Completion / Badge
                        </td>
                    </tr>
                    <tr class="hover:bg-blue-50/30 transition-colors duration-300">
                        <th scope="row" class="px-8 py-5 font-bold text-slate-800 whitespace-nowrap">
                            Highlight
                        </th>
                        <td class="px-8 py-5 font-medium">
                            Capstone Project & Konversi SKS
                        </td>
                        <td class="px-8 py-5 font-medium">
                            Hackathon, Workshop & Rewards
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>

        <!-- Mobile View (Comparison Cards) -->
        <div class="md:hidden space-y-8">
            <!-- Coding Camp Card -->
            <div class="p-8 bg-white/90 backdrop-blur-sm rounded-3xl border border-slate-200 shadow-lg hover:shadow-xl transition-all duration-500 hover:-translate-y-1 relative overflow-hidden group/card">
                <div class="absolute inset-0 bg-gradient-to-br from-transparent via-blue-50/40 to-transparent opacity-0 group-hover/card:opacity-100 transition-opacity duration-700 z-0"></div>
                <div class="absolute top-0 right-0 w-32 h-32 bg-blue-400/10 rounded-full -mr-16 -mt-16 blur-2xl group-hover/card:bg-blue-400/20 transition-colors duration-700"></div>
                <h3 class="text-2xl font-black text-blue-700 mb-6 tracking-tight relative z-10">Coding Camp 2026</h3>
                <ul class="space-y-6 text-slate-700 relative z-10">
                    <li>
                        <span class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-1">Target Audience</span>
                        <span class="font-medium">Mahasiswa, Siswa SMK, Umum</span>
                    </li>
                    <li>
                        <span class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-1">Fokus</span>
                        <span class="font-medium">Hard Skills (Web/AI/Data) + Soft Skills</span>
                    </li>
                    <li>
                        <span class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-1">Sertifikat</span>
                        <span class="font-medium">Sertifikat Kompetensi Dicoding</span>
                    </li>
                    <li>
                        <span class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-1">Highlight</span>
                        <span class="font-medium">Capstone Project & Konversi SKS</span>
                    </li>
                </ul>
            </div>

            <!-- METC Card -->
             <div class="p-8 bg-white/90 backdrop-blur-sm rounded-3xl border border-slate-200 shadow-lg hover:shadow-xl transition-all duration-500 hover:-translate-y-1 relative overflow-hidden group/card">
                <div class="absolute inset-0 bg-gradient-to-br from-transparent via-purple-50/40 to-transparent opacity-0 group-hover/card:opacity-100 transition-opacity duration-700 z-0"></div>
                <div class="absolute top-0 right-0 w-32 h-32 bg-purple-400/10 rounded-full -mr-16 -mt-16 blur-2xl group-hover/card:bg-purple-400/20 transition-colors duration-700"></div>
                <h3 class="text-2xl font-black text-purple-700 mb-6 tracking-tight relative z-10">METC</h3>
                <ul class="space-y-6 text-slate-700 relative z-10">
                    <li>
                        <span class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-1">Target Audience</span>
                        <span class="font-medium">Tech Professional, Aspiring Talent</span>
                    </li>
                    <li>
                        <span class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-1">Fokus</span>
                        <span class="font-medium">Microsoft Tech (Cloud, AI)</span>
                    </li>
                    <li>
                        <span class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-1">Sertifikat</span>
                        <span class="font-medium">Certificate of Completion / Badge</span>
                    </li>
                    <li>
                        <span class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-1">Highlight</span>
                        <span class="font-medium">Hackathon, Workshop & Rewards</span>
                    </li>
                </ul>
            </div>
        </div>
    </div>
</section>
