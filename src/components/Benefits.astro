---
---

<section id="benefits" class="bg-gray-900 py-20 px-4">
    <div class="max-w-screen-xl mx-auto fade-in-up">
        <div class="text-center mb-12">
            <h2 class="text-3xl font-extrabold text-white mb-4">Perbandingan Program</h2>
            <p class="text-gray-400">Temukan yang paling pas untukmu.</p>
        </div>

        <!-- Desktop View (Table) -->
        <div class="hidden md:block relative overflow-x-auto shadow-md sm:rounded-lg max-w-4xl mx-auto">
            <table class="w-full text-sm text-left text-gray-400">
                <thead class="text-xs text-gray-300 uppercase bg-gray-800">
                    <tr>
                        <th scope="col" class="px-6 py-4 w-1/3">Fitur</th>
                        <th scope="col" class="px-6 py-4 w-1/3 text-blue-400">Coding Camp 2026</th>
                        <th scope="col" class="px-6 py-4 w-1/3 text-purple-400">METC</th>
                    </tr>
                </thead>
                <tbody>
                    <tr class="bg-gray-900 border-b border-gray-800 hover:bg-gray-800 transition-colors">
                        <th scope="row" class="px-6 py-4 font-medium text-white whitespace-nowrap">
                            Target Audience
                        </th>
                        <td class="px-6 py-4">
                            Mahasiswa, Siswa SMK, Umum
                        </td>
                        <td class="px-6 py-4">
                            Tech Professional, Aspiring Talent
                        </td>
                    </tr>
                    <tr class="bg-gray-900 border-b border-gray-800 hover:bg-gray-800 transition-colors">
                        <th scope="row" class="px-6 py-4 font-medium text-white whitespace-nowrap">
                            Fokus Utama
                        </th>
                        <td class="px-6 py-4">
                            Hard Skills (Web/AI/Data) + Soft Skills
                        </td>
                        <td class="px-6 py-4">
                            Microsoft Tech (Cloud, AI)
                        </td>
                    </tr>
                    <tr class="bg-gray-900 border-b border-gray-800 hover:bg-gray-800 transition-colors">
                        <th scope="row" class="px-6 py-4 font-medium text-white whitespace-nowrap">
                            Sertifikat
                        </th>
                        <td class="px-6 py-4">
                            Sertifikat Kompetensi Dicoding
                        </td>
                        <td class="px-6 py-4">
                            Certificate of Completion / Badge
                        </td>
                    </tr>
                    <tr class="bg-gray-900 hover:bg-gray-800 transition-colors">
                        <th scope="row" class="px-6 py-4 font-medium text-white whitespace-nowrap">
                            Highlight
                        </th>
                        <td class="px-6 py-4">
                            Capstone Project & Konversi SKS
                        </td>
                        <td class="px-6 py-4">
                            Hackathon, Workshop & Rewards
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>

        <!-- Mobile View (Comparison Cards) -->
        <div class="md:hidden space-y-6">
            <!-- Coding Camp Card -->
            <div class="p-6 bg-gray-800 rounded-lg border border-gray-700">
                <h3 class="text-xl font-bold text-blue-400 mb-4">Coding Camp 2026</h3>
                <ul class="space-y-4 text-gray-300">
                    <li>
                        <span class="block text-xs text-gray-500 uppercase">Target Audience</span>
                        Mahasiswa, Siswa SMK, Umum
                    </li>
                    <li>
                        <span class="block text-xs text-gray-500 uppercase">Fokus</span>
                        Hard Skills (Web/AI/Data) + Soft Skills
                    </li>
                    <li>
                        <span class="block text-xs text-gray-500 uppercase">Sertifikat</span>
                        Sertifikat Kompetensi Dicoding
                    </li>
                    <li>
                        <span class="block text-xs text-gray-500 uppercase">Highlight</span>
                        Capstone Project & Konversi SKS
                    </li>
                </ul>
            </div>

            <!-- METC Card -->
             <div class="p-6 bg-gray-800 rounded-lg border border-gray-700">
                <h3 class="text-xl font-bold text-purple-400 mb-4">METC</h3>
                <ul class="space-y-4 text-gray-300">
                    <li>
                        <span class="block text-xs text-gray-500 uppercase">Target Audience</span>
                        Tech Professional, Aspiring Talent
                    </li>
                    <li>
                        <span class="block text-xs text-gray-500 uppercase">Fokus</span>
                        Microsoft Tech (Cloud, AI)
                    </li>
                    <li>
                        <span class="block text-xs text-gray-500 uppercase">Sertifikat</span>
                        Certificate of Completion / Badge
                    </li>
                    <li>
                        <span class="block text-xs text-gray-500 uppercase">Highlight</span>
                        Hackathon, Workshop & Rewards
                    </li>
                </ul>
            </div>
        </div>
    </div>
</section>
