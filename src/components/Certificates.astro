---
---

<section id="certificates" class="bg-slate-50 py-20 px-4 relative overflow-hidden">
    <!-- Decorative element -->
    <div class="absolute inset-0 overflow-hidden pointer-events-none z-0">
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] bg-gradient-to-tr from-blue-100/30 to-purple-100/30 blur-3xl rounded-full opacity-60"></div>
    </div>

    <div class="max-w-screen-xl mx-auto relative z-10 fade-in-up">
        <div class="text-center mb-16">
            <h2 class="text-3xl font-extrabold text-slate-800 mb-4 tracking-tight">Sertifikasi Kompetensi</h2>
            <p class="text-subtle text-lg max-w-2xl mx-auto">Selesaikan seluruh kurikulum dan dapatkan sertifikat resmi dari Dicoding yang diakui oleh industri sebagai bukti keahlian Anda.</p>
        </div>

        <!-- Marquee / Scrolling Certificates -->
        <div class="relative w-full overflow-hidden [mask-image:_linear-gradient(to_right,transparent_0,_black_128px,_black_calc(100%-128px),transparent_100%)]">
            <div class="animate-marquee flex gap-6 sm:gap-8 min-w-max hover:[animation-play-state:paused] py-4">
                
                <!-- Cert 1 -->
                <div class="w-[280px] sm:w-[350px] md:w-[400px] shrink-0 bg-white p-2 rounded-xl shadow-lg border border-slate-200 hover:shadow-xl hover:border-blue-300 transition-all duration-300 rotate-1 hover:rotate-0 hover:-translate-y-2">
                    <img src="/images/sertif/sertifikat_course_184_4086292_170226043212_page-0001.jpg" alt="Sertifikat Keahlian" class="w-full h-auto rounded-lg" loading="lazy">
                </div>
                
                <!-- Cert 2 -->
                <div class="w-[280px] sm:w-[350px] md:w-[400px] shrink-0 bg-white p-2 rounded-xl shadow-lg border border-slate-200 hover:shadow-xl hover:border-blue-300 transition-all duration-300 -rotate-2 hover:rotate-0 hover:-translate-y-2">
                    <img src="/images/sertif/sertifikat_course_237_4086292_200126141258_page-0001.jpg" alt="Sertifikat Kelulusan" class="w-full h-auto rounded-lg" loading="lazy">
                </div>

                <!-- Cert 3 -->
                <div class="w-[280px] sm:w-[350px] md:w-[400px] shrink-0 bg-white p-2 rounded-xl shadow-lg border border-slate-200 hover:shadow-xl hover:border-blue-300 transition-all duration-300 rotate-2 hover:rotate-0 hover:-translate-y-2">
                    <img src="/images/sertif/sertifikat_course_615_4086292_220924142522_page-0001.jpg" alt="Sertifikat Microsoft" class="w-full h-auto rounded-lg" loading="lazy">
                </div>

                <!-- Cert 4 -->
                <div class="w-[280px] sm:w-[350px] md:w-[400px] shrink-0 bg-white p-2 rounded-xl shadow-lg border border-slate-200 hover:shadow-xl hover:border-blue-300 transition-all duration-300 -rotate-1 hover:rotate-0 hover:-translate-y-2">
                    <img src="/images/sertif/sertifikat_course_653_4086292_020226120102_page-0001.jpg" alt="Sertifikat Kompetensi" class="w-full h-auto rounded-lg" loading="lazy">
                </div>

                <!-- Cert 5 -->
                <div class="w-[280px] sm:w-[350px] md:w-[400px] shrink-0 bg-white p-2 rounded-xl shadow-lg border border-slate-200 hover:shadow-xl hover:border-blue-300 transition-all duration-300 rotate-1 hover:rotate-0 hover:-translate-y-2">
                    <img src="/images/sertif/sertifikat_course_86_4086292_060226231344_page-0001.jpg" alt="Sertifikat Penyelesaian" class="w-full h-auto rounded-lg" loading="lazy">
                </div>

                 <!-- Duplicate exactly the same for seamless loop -->
                 <div class="w-[280px] sm:w-[350px] md:w-[400px] shrink-0 bg-white p-2 rounded-xl shadow-lg border border-slate-200 hover:shadow-xl hover:border-blue-300 transition-all duration-300 rotate-1 hover:rotate-0 hover:-translate-y-2">
                    <img src="/images/sertif/sertifikat_course_184_4086292_170226043212_page-0001.jpg" alt="Sertifikat Keahlian" class="w-full h-auto rounded-lg" loading="lazy">
                </div>
                
                <div class="w-[280px] sm:w-[350px] md:w-[400px] shrink-0 bg-white p-2 rounded-xl shadow-lg border border-slate-200 hover:shadow-xl hover:border-blue-300 transition-all duration-300 -rotate-2 hover:rotate-0 hover:-translate-y-2">
                    <img src="/images/sertif/sertifikat_course_237_4086292_200126141258_page-0001.jpg" alt="Sertifikat Kelulusan" class="w-full h-auto rounded-lg" loading="lazy">
                </div>

                <div class="w-[280px] sm:w-[350px] md:w-[400px] shrink-0 bg-white p-2 rounded-xl shadow-lg border border-slate-200 hover:shadow-xl hover:border-blue-300 transition-all duration-300 rotate-2 hover:rotate-0 hover:-translate-y-2">
                    <img src="/images/sertif/sertifikat_course_615_4086292_220924142522_page-0001.jpg" alt="Sertifikat Microsoft" class="w-full h-auto rounded-lg" loading="lazy">
                </div>

                <div class="w-[280px] sm:w-[350px] md:w-[400px] shrink-0 bg-white p-2 rounded-xl shadow-lg border border-slate-200 hover:shadow-xl hover:border-blue-300 transition-all duration-300 -rotate-1 hover:rotate-0 hover:-translate-y-2">
                    <img src="/images/sertif/sertifikat_course_653_4086292_020226120102_page-0001.jpg" alt="Sertifikat Kompetensi" class="w-full h-auto rounded-lg" loading="lazy">
                </div>

                <div class="w-[280px] sm:w-[350px] md:w-[400px] shrink-0 bg-white p-2 rounded-xl shadow-lg border border-slate-200 hover:shadow-xl hover:border-blue-300 transition-all duration-300 rotate-1 hover:rotate-0 hover:-translate-y-2">
                    <img src="/images/sertif/sertifikat_course_86_4086292_060226231344_page-0001.jpg" alt="Sertifikat Penyelesaian" class="w-full h-auto rounded-lg" loading="lazy">
                </div>
            </div>
        </div>

    </div>
</section>

<style>
    @keyframes marquee {
        0% { transform: translateX(0); }
        100% { transform: translateX(calc(-50% - (1.5rem / 2))); } /* 50% shift including gap */
    }
    .animate-marquee {
        animation: marquee 35s linear infinite;
    }
</style>
