---
---
<nav class="fixed w-full z-50 top-0 start-0 border-b border-subtle-light/60 bg-white/80 backdrop-blur-lg shadow-sm transition-all duration-300">
  <div class="max-w-screen-xl flex flex-wrap items-center justify-between mx-auto p-4 transition-all duration-300 group-hover:p-5">
    <!-- Brand -->
    <a href="#" class="flex items-center space-x-3 rtl:space-x-reverse z-50 relative group outline-none">
        <div class="relative overflow-hidden rounded-lg shadow-sm border border-slate-200 hover:shadow-glow transition-all duration-300 hover:-translate-y-0.5 bg-white">
            <img src="/images/icon.jpg" alt="Dicoding Icon" class="w-10 h-10 object-cover group-hover:scale-110 transition-transform duration-500" />
        </div>
        <span class="self-center text-xl font-extrabold whitespace-nowrap text-slate-800 tracking-tight transition-colors duration-300">
          Beasiswa <span class="text-primary hover:text-primary-dark transition-colors">Coding</span> & <span class="text-secondary hover:text-purple-600 transition-colors">AI Hub</span>
        </span>
    </a>

    <!-- Mobile Menu Button -->
    <button id="mobile-menu-btn" type="button" class="inline-flex items-center p-2 w-10 h-10 justify-center text-sm text-subtle rounded-lg md:hidden hover:bg-slate-100 hover:text-primary focus:outline-none focus:ring-2 focus:ring-slate-100 z-50 relative transition-all duration-300" aria-controls="navbar-default" aria-expanded="false" aria-label="Toggle navigation">
        <span class="sr-only">Open main menu</span>
        <svg class="w-5 h-5 hamburger-icon" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 17 14">
            <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M1 1h15M1 7h15M1 13h15"/>
        </svg>
        <svg class="w-5 h-5 close-icon hidden scale-75 opacity-0 transition-all duration-300" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 14 14">
            <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 1 6 6m0 0 6 6M7 7l6-6M7 7l-6 6"/>
        </svg>
    </button>

    <!-- Desktop Menu -->
    <div class="hidden w-full md:block md:w-auto" id="navbar-desktop">
      <ul class="font-medium flex flex-col p-4 md:p-0 mt-4 border border-slate-100 bg-white/50 rounded-lg md:flex-row md:space-x-8 rtl:space-x-reverse md:mt-0 md:border-0 md:bg-transparent shadow-sm md:shadow-none items-center">
        <li>
          <a href="#programs" class="relative block py-2 px-6 text-white bg-primary rounded-xl md:bg-primary font-bold hover:bg-primary-dark shadow-md hover:shadow-glow hover:-translate-y-1 transition-all duration-300 overflow-hidden group" aria-current="page">
             <span class="absolute inset-0 w-full h-full bg-gradient-to-r from-transparent via-white/30 to-transparent -translate-x-full group-hover:animate-[shimmer_1s_infinite]"></span>
             <span class="relative z-10">Programs</span>
          </a>
        </li>
        <li>
          <a href="#benefits" class="block py-2 px-3 text-slate-600 rounded-lg hover:bg-slate-50 hover:text-primary md:hover:bg-transparent md:border-0 md:hover:text-primary-dark transition-all duration-300">Benefits</a>
        </li>
        <li>
          <a href="#timeline" class="block py-2 px-3 text-slate-600 rounded-lg hover:bg-slate-50 hover:text-primary md:hover:bg-transparent md:border-0 md:hover:text-primary-dark transition-all duration-300">Timeline</a>
        </li>
        <li>
          <a href="#faq" class="block py-2 px-3 text-slate-600 rounded-lg hover:bg-slate-50 hover:text-primary md:hover:bg-transparent md:border-0 md:hover:text-primary-dark transition-all duration-300">FAQ</a>
        </li>
      </ul>
    </div>
  </div>

  <!-- Mobile Drawer Overlay -->
  <div id="mobile-drawer" class="fixed inset-0 z-40 bg-white/95 backdrop-blur-xl transform translate-x-full transition-transform duration-500 ease-[cubic-bezier(0.4,0,0.2,1)] md:hidden flex flex-col pt-24 px-6 pb-8">
      <ul class="flex flex-col space-y-4 text-xl font-bold w-full">
        <li>
          <a href="#programs" class="mobile-link flex items-center justify-between py-4 px-6 bg-blue-50/50 border border-blue-100 rounded-2xl text-blue-700 hover:bg-blue-600 hover:text-white hover:border-blue-600 shadow-sm transition-all duration-300 group">
              <span>Programs</span>
              <svg class="w-5 h-5 opacity-50 group-hover:opacity-100 group-hover:translate-x-1 transition-all" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
          </a>
        </li>
        <li>
          <a href="#benefits" class="mobile-link flex items-center justify-between py-4 px-6 rounded-2xl text-slate-700 hover:bg-slate-50 hover:text-blue-600 transition-all duration-300 group">
              <span>Benefits</span>
              <svg class="w-5 h-5 opacity-0 group-hover:opacity-100 group-hover:translate-x-1 transition-all" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
          </a>
        </li>
        <li>
          <a href="#timeline" class="mobile-link flex items-center justify-between py-4 px-6 rounded-2xl text-slate-700 hover:bg-slate-50 hover:text-blue-600 transition-all duration-300 group">
              <span>Timeline</span>
              <svg class="w-5 h-5 opacity-0 group-hover:opacity-100 group-hover:translate-x-1 transition-all" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
          </a>
        </li>
        <li>
          <a href="#faq" class="mobile-link flex items-center justify-between py-4 px-6 rounded-2xl text-slate-700 hover:bg-slate-50 hover:text-blue-600 transition-all duration-300 group">
              <span>FAQ</span>
              <svg class="w-5 h-5 opacity-0 group-hover:opacity-100 group-hover:translate-x-1 transition-all" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
          </a>
        </li>
      </ul>
      
      <!-- Mobile Drawer Footer Info -->
      <div class="mt-auto items-center justify-center flex flex-col space-y-4 pt-8 border-t border-slate-100">
           <img src="/images/icon.jpg" alt="Dicoding Logo" class="w-12 h-12 rounded-xl shadow-sm border border-slate-200" />
           <p class="text-sm font-medium text-slate-500 text-center">Beasiswa Coding & AI Hub<br/>© 2026 Dicoding Promo</p>
      </div>
  </div>
</nav>

<script>
    const btn = document.getElementById('mobile-menu-btn');
    const drawer = document.getElementById('mobile-drawer');
    const hamburgerIcon = document.querySelector('.hamburger-icon');
    const closeIcon = document.querySelector('.close-icon');
    const mobileLinks = document.querySelectorAll('.mobile-link');

    if (btn && drawer && hamburgerIcon && closeIcon) {
        btn.addEventListener('click', () => {
            const isExpanded = btn.getAttribute('aria-expanded') === 'true';
            btn.setAttribute('aria-expanded', !isExpanded);
            
            drawer.classList.toggle('translate-x-full');
            
            // Toggle icons
            hamburgerIcon.classList.toggle('hidden');
            closeIcon.classList.toggle('hidden');
            
            // Toggle body scroll
            document.body.classList.toggle('overflow-hidden');
        });

        // Close drawer when link clicked
        mobileLinks.forEach(link => {
            link.addEventListener('click', () => {
                drawer.classList.add('translate-x-full');
                btn.setAttribute('aria-expanded', 'false');
                hamburgerIcon.classList.remove('hidden');
                closeIcon.classList.add('hidden');
                document.body.classList.remove('overflow-hidden');
            });
        });
    }
</script>
