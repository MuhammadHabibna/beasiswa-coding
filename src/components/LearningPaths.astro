---
---

<section id="learning-paths" class="bg-slate-50 py-20 px-4 relative overflow-hidden">
    <!-- Decorative Vector Background -->
    <div class="absolute inset-0 overflow-hidden pointer-events-none z-0">
        <svg class="absolute -top-24 -left-24 w-96 h-96 text-blue-200/40 blur-3xl opacity-60" fill="currentColor" viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg">
            <path d="M45.7,35.1C55.6,47.9,64.2,63.1,65.3,79.1c1.1,16-5.3,32.8-15.5,45.4C39.6,137.1,25.6,145.6,10.6,144C-4.4,142.4-20.4,130.6-32.9,117.1c-12.5-13.5-21.5-28.7-25-45.1c-3.5-16.4,1.8-34,12.7-47.5C-34.3,11-17.1,1.7-0.9,0.7C15.3-0.3,35.8,22.3,45.7,35.1z" transform="translate(100 100)"></path>
        </svg>
        <svg class="absolute bottom-10 right-10 w-full max-w-lg h-full max-h-lg text-purple-200/40 blur-3xl opacity-60 translate-x-1/3 translate-y-1/3" fill="currentColor" viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg">
            <path d="M44.7,-76.4C58.8,-69.2,71.8,-59.1,81.3,-46.3C90.8,-33.5,96.8,-18.1,97.7,-2.3C98.6,13.5,94.3,29.8,85.2,43.3C76.1,56.8,62.1,67.6,46.9,75.1C31.7,82.6,15.8,86.8,0.2,86.5C-15.4,86.2,-30.8,81.4,-44.6,73.1C-58.4,64.8,-70.6,53.1,-79.1,39C-87.6,24.9,-92.4,8.4,-90.6,-7.3C-88.8,-23,-80.4,-37.9,-70.1,-50.4C-59.8,-62.9,-47.5,-73.1,-33.9,-79.6C-20.3,-86.1,-5.3,-88.9,9.4,-88.5C24.1,-88.1,42.7,-84.6,44.7,-76.4Z" transform="translate(100 100) scale(1.1)"></path>
        </svg>
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full h-[150%] bg-[radial-gradient(ellipse_at_center,_var(--tw-gradient-stops))] from-white/40 via-transparent to-transparent"></div>
    </div>

    <div class="max-w-screen-xl mx-auto fade-in-up relative z-10">
        <div class="text-center mb-12">
            <h2 class="text-3xl font-extrabold text-slate-800 mb-4">Alur Belajar</h2>
            <p class="text-slate-600">Pilih kurikulum berstandar global yang dirancang khusus untuk mengembangkan kemampuan teknis, non-teknis, dan persiapan karier.</p>
        </div>

        <div class="grid lg:grid-cols-2 gap-8">
            <!-- Coding Camp Section -->
            <div class="bg-white rounded-2xl p-6 lg:p-8 border border-blue-100 shadow-xl shadow-blue-500/5 backdrop-blur-sm">
                <div class="flex items-center gap-3 mb-8">
                    <div class="p-3 bg-blue-50 rounded-lg shrink-0">
                        <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path></svg>
                    </div>
                    <h3 class="text-2xl font-bold text-slate-800">Coding Camp 2.0</h3>
                </div>

                <div class="grid sm:grid-cols-2 gap-6">
                    <!-- Gen AI Engineer -->
                    <!-- Gen AI Engineer -->
                    <div class="bg-blue-50/80 rounded-xl p-5 border border-blue-200 hover:border-blue-400 transition-colors hover:shadow-lg relative overflow-hidden group">
                        <div class="absolute inset-0 bg-gradient-to-r from-transparent via-blue-200/50 to-transparent translate-x-[-100%] group-hover:translate-x-[100%] transition-transform duration-700 z-0"></div>
                        <div class="relative z-10">
                            <h4 class="text-lg font-bold text-blue-900 mb-3">Gen AI Engineer</h4>
                            <ul class="space-y-2 text-sm text-blue-800 list-disc ml-4">
                                <li>Belajar Dasar AI</li>
                                <li>Prompt Engineering untuk Software Developer</li>
                                <li>Memulai Pemrograman dengan Python</li>
                                <li>Belajar Machine Learning untuk Pemula</li>
                                <li class="mt-2 pt-2 border-t border-blue-200/50 list-none -ml-4 pl-4">
                                    <span class="font-bold text-blue-900 block mb-1">Soft Skills:</span>
                                    <ul class="list-disc ml-4 space-y-1">
                                        <li>Belajar Strategi Pengembangan Diri</li>
                                    </ul>
                                </li>
                            </ul>
                        </div>
                    </div>
                    
                    <!-- Data Scientist -->
                    <div class="bg-emerald-50/80 rounded-xl p-5 border border-emerald-200 hover:border-emerald-400 transition-colors hover:shadow-lg relative overflow-hidden group">
                        <div class="absolute inset-0 bg-gradient-to-r from-transparent via-emerald-200/50 to-transparent translate-x-[-100%] group-hover:translate-x-[100%] transition-transform duration-700 z-0"></div>
                        <div class="relative z-10">
                            <h4 class="text-lg font-bold text-emerald-900 mb-3">Data Scientist</h4>
                            <ul class="space-y-2 text-sm text-emerald-800 list-disc ml-4">
                                <li>Belajar Dasar Data Science</li>
                                <li>Belajar Dasar Structured Query Language (SQL)</li>
                                <li>Memulai Pemrograman dengan Python</li>
                                <li>Belajar Machine Learning untuk Pemula</li>
                                <li class="mt-2 pt-2 border-t border-emerald-200/50 list-none -ml-4 pl-4">
                                    <span class="font-bold text-emerald-900 block mb-1">Soft Skills:</span>
                                    <ul class="list-disc ml-4 space-y-1">
                                        <li>Belajar Strategi Pengembangan Diri</li>
                                    </ul>
                                </li>
                            </ul>
                        </div>
                    </div>

                    <!-- Full-Stack Web Developer -->
                    <div class="bg-amber-50/80 rounded-xl p-5 border border-amber-200 hover:border-amber-400 transition-colors hover:shadow-lg relative overflow-hidden group">
                        <div class="absolute inset-0 bg-gradient-to-r from-transparent via-amber-200/50 to-transparent translate-x-[-100%] group-hover:translate-x-[100%] transition-transform duration-700 z-0"></div>
                        <div class="relative z-10">
                            <h4 class="text-lg font-bold text-amber-900 mb-3">Full-stack Developer</h4>
                            <ul class="space-y-2 text-sm text-amber-800 list-disc ml-4">
                                <li>Belajar Dasar Pemrograman Web</li>
                                <li>Belajar Dasar Pemrograman JavaScript</li>
                                <li>Belajar Membuat Front-End Web untuk Pemula</li>
                                <li>Belajar Membuat Aplikasi Web dengan React</li>
                                <li class="mt-2 pt-2 border-t border-amber-200/50 list-none -ml-4 pl-4">
                                    <span class="font-bold text-amber-900 block mb-1">Soft Skills:</span>
                                    <ul class="list-disc ml-4 space-y-1">
                                        <li>Belajar Strategi Pengembangan Diri</li>
                                    </ul>
                                </li>
                            </ul>
                        </div>
                    </div>

                    <!-- AI Engineer -->
                    <div class="bg-rose-50/80 rounded-xl p-5 border border-rose-200 hover:border-rose-400 transition-colors hover:shadow-lg relative overflow-hidden group">
                        <div class="absolute inset-0 bg-gradient-to-r from-transparent via-rose-200/50 to-transparent translate-x-[-100%] group-hover:translate-x-[100%] transition-transform duration-700 z-0"></div>
                        <div class="relative z-10">
                            <h4 class="text-lg font-bold text-rose-900 mb-3">AI Engineer</h4>
                            <ul class="space-y-2 text-sm text-rose-800 list-disc ml-4">
                                <li>Belajar Dasar AI</li>
                                <li>Memulai Pemrograman dengan Python</li>
                                <li>Belajar Machine Learning untuk Pemula</li>
                                <li class="mt-2 pt-2 border-t border-rose-200/50 list-none -ml-4 pl-4">
                                    <span class="font-bold text-rose-900 block mb-1">Soft Skills:</span>
                                    <ul class="list-disc ml-4 space-y-1">
                                        <li>Belajar Strategi Pengembangan Diri</li>
                                    </ul>
                                </li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>

            <!-- METC Section -->
            <div class="bg-white rounded-2xl p-6 lg:p-8 border border-purple-100 shadow-xl shadow-purple-500/5 backdrop-blur-sm">
                <div class="flex items-center gap-3 mb-8">
                    <div class="p-3 bg-purple-50 rounded-lg shrink-0">
                        <svg class="w-6 h-6 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"></path></svg>
                    </div>
                    <h3 class="text-2xl font-bold text-slate-800">Microsoft Elevate Training Center</h3>
                </div>

                <div class="space-y-6">
                    <!-- Promo Banner -->
                    <div class="bg-gradient-to-r from-purple-600 to-indigo-600 rounded-xl p-5 text-white shadow-md relative overflow-hidden group">
                        <div class="absolute inset-0 bg-white/10 translate-x-[-100%] group-hover:translate-x-[100%] transition-transform duration-700"></div>
                        <h4 class="text-sm font-bold mb-1 flex items-center gap-2">
                            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path d="M5 3a2 2 0 00-2 2v2a2 2 0 002 2h2a2 2 0 002-2V5a2 2 0 00-2-2H5zM5 11a2 2 0 00-2 2v2a2 2 0 002 2h2a2 2 0 002-2v-2a2 2 0 00-2-2H5zM11 5a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V5zM11 13a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"/></svg>
                            Akses Materi Tanpa Seleksi Awal!
                        </h4>
                        <p class="text-[10px] leading-relaxed opacity-90">
                            Raih kesempatan mendapatkan <strong>rewards spesial</strong>, serta berpartisipasi di <strong>Hackathon & Datathon</strong> dengan menyelesaikan seluruh kelas.
                        </p>
                    </div>

                    <!-- Level Awal -->
                    <div class="bg-slate-50 rounded-xl p-5 border border-slate-200">
                        <div class="flex items-center justify-between mb-4">
                            <h4 class="text-lg font-bold text-slate-800">Kelas Level Awal</h4>
                            <span class="text-[10px] font-bold uppercase tracking-wider bg-green-100 text-green-700 px-2 py-1 rounded">Pondasi Utama</span>
                        </div>
                        
                        <div class="space-y-4">
                            <!-- Tahap 1 -->
                            <!-- Tahap 1 -->
                            <div class="bg-white p-4 rounded-lg border border-slate-100 shadow-sm relative overflow-hidden group">
                                <div class="absolute inset-0 bg-gradient-to-r from-transparent via-purple-100/40 to-transparent translate-x-[-100%] group-hover:translate-x-[100%] transition-transform duration-700 z-0"></div>
                                <div class="relative z-10">
                                    <h5 class="text-sm font-bold text-purple-600 mb-2">Tahap 1</h5>
                                    <ul class="space-y-1.5 text-xs text-slate-600 list-disc ml-4">
                                        <li>Belajar Penerapan Data Science dengan Microsoft Fabric</li>
                                        <li>Membangun Aplikasi Gen AI dengan Microsoft Azure</li>
                                    </ul>
                                    <p class="mt-2 text-[10px] text-slate-500 italic">*Langsung dapat diakses ketika berhasil mendaftar</p>
                                </div>
                            </div>

                            <!-- Tahap 2 -->
                            <!-- Tahap 2 -->
                            <div class="bg-white p-4 rounded-lg border border-slate-100 shadow-sm relative overflow-hidden group">
                                <div class="absolute inset-0 bg-gradient-to-r from-transparent via-purple-100/40 to-transparent translate-x-[-100%] group-hover:translate-x-[100%] transition-transform duration-700 z-0"></div>
                                <div class="relative z-10">
                                    <h5 class="text-sm font-bold text-purple-600 mb-2">Tahap 2</h5>
                                    <ul class="space-y-1.5 text-xs text-slate-600 list-disc ml-4">
                                        <li>Memulai Pemrograman dengan Python</li>
                                        <li>Belajar Machine Learning untuk Pemula</li>
                                        <li>Belajar Fundamental Pemrosesan Data</li>
                                    </ul>
                                    <div class="mt-3 p-3 bg-purple-50 rounded-lg border border-purple-100">
                                        <p class="text-[10px] text-purple-700 leading-relaxed font-medium mb-2">
                                            <strong>Syarat akses:</strong> Ajak minimal 1 rekan & upload twibbon menggunakan aset berikut:
                                        </p>
                                        <div class="flex gap-2 relative z-20">
                                            <a href="#" class="text-[9px] bg-white border border-purple-200 text-purple-600 px-2 py-1 rounded hover:bg-purple-600 hover:text-white transition-colors font-bold">Link Twibbon</a>
                                            <a href="#" class="text-[9px] bg-white border border-purple-200 text-purple-600 px-2 py-1 rounded hover:bg-purple-600 hover:text-white transition-colors font-bold">Link Caption</a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Level Lanjutan -->
                    <!-- Level Lanjutan -->
                    <div class="bg-purple-50/80 rounded-xl p-5 border border-purple-200 relative overflow-hidden group">
                        <div class="absolute inset-0 bg-gradient-to-r from-transparent via-purple-200/50 to-transparent translate-x-[-100%] group-hover:translate-x-[100%] transition-transform duration-700 z-0"></div>
                        <div class="relative z-10">
                            <div class="flex items-center justify-between mb-4">
                                <h4 class="text-lg font-bold text-purple-900">Kelas Level Lanjutan</h4>
                                <span class="text-[10px] font-bold uppercase tracking-wider bg-purple-200 text-purple-800 px-2 py-1 rounded">Seleksi</span>
                            </div>
                            <ul class="space-y-1.5 text-xs text-purple-800 list-disc ml-4 font-medium">
                                <li>Belajar Fundamental Gen AI (Segera hadir)</li>
                                <li>Membangun Sistem Machine Learning</li>
                            </ul>
                            <p class="mt-4 text-[10px] text-purple-700 italic border-t border-purple-200 pt-3">
                                Peserta terbaik hasil seleksi hingga 26 Maret 2026 akan mendapatkan akses eksklusif.
                            </p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Pijak Section -->
            <div class="bg-white rounded-2xl p-6 lg:p-8 border border-emerald-100 shadow-xl shadow-emerald-500/5 backdrop-blur-sm lg:col-span-2">
                <div class="flex items-center gap-3 mb-8">
                    <div class="p-3 bg-emerald-50 rounded-lg shrink-0">
                        <svg class="w-6 h-6 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
                    </div>
                    <h3 class="text-2xl font-bold text-slate-800">Pijak x IBM SkillsBuild</h3>
                </div>

                <div class="space-y-6">
                    <!-- Promo Banner -->
                    <div class="bg-gradient-to-r from-emerald-600 to-teal-600 rounded-xl p-5 text-white shadow-md relative overflow-hidden group">
                        <div class="absolute inset-0 bg-white/10 translate-x-[-100%] group-hover:translate-x-[100%] transition-transform duration-700"></div>
                        <h4 class="text-sm font-bold mb-1 flex items-center gap-2">
                            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path d="M5 3a2 2 0 00-2 2v2a2 2 0 002 2h2a2 2 0 002-2V5a2 2 0 00-2-2H5zM5 11a2 2 0 00-2 2v2a2 2 0 002 2h2a2 2 0 002-2v-2a2 2 0 00-2-2H5zM11 5a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V5zM11 13a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"/></svg>
                            Mencetak AI Engineer Andal
                        </h4>
                        <p class="text-[10px] leading-relaxed opacity-90 text-base">
                            Jadilah bagian dari generasi AI Indonesia. Pelatihan 100% gratis secara online menggunakan kurikulum berstandar industri global.
                        </p>
                    </div>

                    <div class="bg-slate-50 rounded-xl p-5 border border-slate-200">
                        <div class="grid md:grid-cols-2 gap-4">
                            <!-- Kelas Teknis -->
                            <div class="bg-white p-4 rounded-lg border border-slate-100 shadow-sm relative overflow-hidden group">
                                <div class="absolute inset-0 bg-gradient-to-r from-transparent via-emerald-100/40 to-transparent translate-x-[-100%] group-hover:translate-x-[100%] transition-transform duration-700 z-0"></div>
                                <div class="relative z-10">
                                    <h5 class="text-sm font-bold text-emerald-600 mb-2">Kelas Teknis</h5>
                                    <ul class="space-y-1.5 text-xs text-slate-600 list-disc ml-4">
                                        <li>Belajar Dasar AI</li>
                                        <li>Memulai Pemrograman dengan Python</li>
                                        <li>Belajar Machine Learning untuk Pemula</li>
                                        <li>Belajar Fundamental Deep Learning</li>
                                        <li>Membangun Sistem Machine Learning</li>
                                    </ul>
                                </div>
                            </div>

                            <!-- Bonus Kelas -->
                            <div class="bg-white p-4 rounded-lg border border-slate-100 shadow-sm relative overflow-hidden group">
                                <div class="absolute inset-0 bg-gradient-to-r from-transparent via-emerald-100/40 to-transparent translate-x-[-100%] group-hover:translate-x-[100%] transition-transform duration-700 z-0"></div>
                                <div class="relative z-10">
                                    <h5 class="text-sm font-bold text-emerald-600 mb-2">Bonus Kelas *</h5>
                                    <ul class="space-y-1.5 text-xs text-slate-600 list-disc ml-4">
                                        <li>AI Praktis untuk Produktivitas</li>
                                        <li>Belajar Dasar Visualisasi Data</li>
                                        <li>Belajar Dasar SQL</li>
                                        <li>Belajar Analisis Data dengan Python</li>
                                        <li>Belajar Fundamental Pemrosesan Data</li>
                                        <li>Machine Learning Terapan</li>
                                    </ul>
                                    <p class="mt-2 text-[10px] text-slate-500 italic">*syarat & ketentuan berlaku.</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
