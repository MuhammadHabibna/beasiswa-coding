---
---

<section class="relative bg-background pt-32 pb-20 lg:pt-40 lg:pb-28 overflow-hidden min-h-[90vh] flex flex-col justify-center">
    <!-- Animated Soft Blobs -->
    <div class="absolute top-0 -left-4 w-96 h-96 bg-primary/10 rounded-full mix-blend-multiply filter blur-[100px] opacity-60 animate-blob"></div>
    <div class="absolute top-0 -right-4 w-96 h-96 bg-secondary/10 rounded-full mix-blend-multiply filter blur-[100px] opacity-60 animate-blob animation-delay-2000"></div>
    <div class="absolute -bottom-8 left-20 w-96 h-96 bg-accent/10 rounded-full mix-blend-multiply filter blur-[100px] opacity-50 animate-blob animation-delay-4000"></div>

    <div class="relative z-10 max-w-screen-xl mx-auto px-4 sm:px-6 text-center fade-in-up">
        <div class="inline-flex items-center justify-center px-4 py-1.5 md:px-5 md:py-2 mb-6 md:mb-8 text-xs md:text-sm font-medium text-primary bg-primary/5 rounded-full border border-primary/20 shadow-sm transition-colors hover:shadow-md duration-300">
            <span class="relative flex h-2.5 w-2.5 md:h-3 md:w-3 mr-2 md:mr-3">
                <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-primary/70 opacity-75"></span>
                <span class="relative inline-flex rounded-full h-2.5 w-2.5 md:h-3 md:w-3 bg-primary"></span>
            </span>
            Pendaftaran Dibuka Sekarang
        </div>
        
        <h1 class="mb-6 md:mb-8 text-4xl sm:text-5xl font-extrabold tracking-tight leading-snug md:leading-loose lg:text-7xl">
            <span class="text-slate-800">Upgrade Skill IT Lewat</span><br class="hidden sm:block" />
            <span class="bg-clip-text text-transparent bg-gradient-to-r from-primary via-secondary to-accent py-1 md:py-2 drop-shadow-sm leading-normal">
                Beasiswa & Pelatihan Resmi
            </span>
        </h1>
        
        <p class="mb-8 md:mb-10 text-base sm:text-lg font-medium text-subtle lg:text-xl px-2 sm:px-16 xl:px-48 transition-colors duration-300">
            Satu halaman untuk dua program unggulan: <strong class="text-slate-700 font-bold">Coding Camp 2026</strong> (powered by DBS Foundation) & <strong class="text-slate-700 font-bold">Microsoft Elevate Training Center</strong> (METC).
        </p>
        
        <div class="flex flex-col sm:flex-row justify-center items-center gap-4 sm:gap-5 w-full max-w-md mx-auto sm:max-w-none relative z-20">
            <a href="https://www.dicoding.com/codingcamp/registration?ref=4394693" target="_blank" rel="noopener noreferrer" class="group relative inline-flex justify-center items-center py-3.5 px-6 md:py-4 md:px-8 text-sm md:text-base font-bold text-center text-white rounded-xl bg-primary hover:bg-primary-dark focus:ring-4 focus:ring-primary/30 transition-all shadow-premium hover:shadow-glow hover:-translate-y-1 md:hover:-translate-y-2 duration-300 overflow-hidden w-full sm:w-auto">
                <span class="absolute inset-0 w-full h-full bg-gradient-to-r from-transparent via-white/20 to-transparent -translate-x-full group-hover:animate-[shimmer_1.5s_infinite]"></span>
                <span class="relative z-10 flex items-center">
                    Daftar Coding Camp
                    <svg class="w-4 h-4 ms-2 group-hover:translate-x-1 transition-transform" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 14 10">
                        <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M1 5h12m0 0L9 1m4 4L9 9"/>
                    </svg>
                </span>
            </a>
            <a href="https://www.dicoding.com/elevate/registration?ref=4394693" target="_blank" rel="noopener noreferrer" class="group relative inline-flex justify-center items-center py-3.5 px-6 md:py-4 md:px-8 text-sm md:text-base font-bold text-center text-slate-700 bg-surface rounded-xl border-2 border-subtle-light hover:bg-subtle-light hover:border-slate-300 hover:text-primary focus:ring-4 focus:ring-slate-100 transition-all shadow-sm hover:shadow-hover-premium hover:-translate-y-1 md:hover:-translate-y-2 duration-300 w-full sm:w-auto">
                Daftar METC
            </a>
        </div>
        
        <p class="mt-8 text-sm text-subtle font-medium">
            *Pendaftaran dilakukan di platform Dicoding (akan diminta login).
        </p>
    </div>
</section>

<style>
    @keyframes blob {
        0% { transform: translate(0px, 0px) scale(1); }
        33% { transform: translate(30px, -50px) scale(1.1); }
        66% { transform: translate(-20px, 20px) scale(0.9); }
        100% { transform: translate(0px, 0px) scale(1); }
    }
    .animate-blob {
        animation: blob 7s infinite;
    }
    .animation-delay-2000 {
        animation-delay: 2s;
    }
    .animation-delay-4000 {
        animation-delay: 4s;
    }
</style>
