---
---

<section id="requirements" class="bg-slate-50 py-20 px-4 relative overflow-hidden">
    <!-- Decorative Vector Background -->
    <div class="absolute inset-0 overflow-hidden pointer-events-none z-0">
        <svg class="absolute top-0 right-0 w-[500px] h-[500px] text-emerald-200/40 blur-3xl opacity-50 translate-x-1/2 -translate-y-1/2" fill="currentColor" viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg">
            <path d="M47.7,-57.2C59.4,-47.3,64.9,-29.3,67.6,-11.1C70.3,7.1,70.2,25.6,61.8,40.1C53.4,54.6,36.7,65.1,18.7,70.6C0.7,76.1,-18.6,76.6,-35.1,69.5C-51.6,62.4,-65.4,47.7,-72.1,30.3C-78.8,12.9,-78.4,-7.2,-70.6,-23.7C-62.8,-40.2,-47.6,-53.1,-32,-61.7C-16.4,-70.3,2.4,-74.6,20.1,-70.1C37.8,-65.6,56,-45,-47.7,-57.2Z" transform="translate(100 100) scale(1.1)"></path>
        </svg>
    </div>

    <div class="max-w-screen-xl mx-auto fade-in-up relative z-10">
        <div class="text-center mb-12">
            <h2 class="text-3xl font-extrabold text-slate-800 mb-4">Syarat Pendaftaran</h2>
            <p class="text-slate-600">Pastikan Anda memenuhi kriteria berikut sebelum mendaftar program.</p>
        </div>

        <div class="grid md:grid-cols-2 gap-8">
            <!-- Coding Camp Requirements -->
            <div class="bg-white/90 backdrop-blur-sm rounded-2xl p-6 lg:p-8 border border-slate-200 hover:border-blue-400 transition-colors shadow-lg hover:shadow-xl relative overflow-hidden group">
                <div class="absolute inset-0 bg-gradient-to-r from-transparent via-blue-50/50 to-transparent translate-x-[-100%] group-hover:translate-x-[100%] transition-transform duration-700 z-0"></div>
                <div class="relative z-10">
                    <h3 class="text-2xl font-bold text-blue-700 mb-6 border-b border-slate-100 pb-4">Coding Camp 2.0</h3>
                <ul class="space-y-4">
                    <li class="flex items-start gap-3">
                        <svg class="w-6 h-6 text-green-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                        <span class="text-slate-700">Warga Negara Indonesia (WNI)</span>
                    </li>
                    <li class="flex items-start gap-3">
                        <svg class="w-6 h-6 text-green-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                        <span class="text-slate-700">Terbuka untuk umum</span>
                    </li>
                    <li class="flex items-start gap-3">
                        <svg class="w-6 h-6 text-green-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                        <span class="text-slate-700">Berkomitmen mengikuti program hingga akhir</span>
                    </li>
                    <li class="flex items-start gap-3">
                        <svg class="w-6 h-6 text-green-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                        <span class="text-slate-700">Memiliki laptop atau komputer, serta memiliki jaringan internet</span>
                    </li>
                    <li class="flex items-start gap-3">
                        <svg class="w-6 h-6 text-green-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                        <span class="text-slate-700">Belum pernah mendaftar program Coding Camp 2025 atau Coding Camp 2026 1.0</span>
                    </li>
                </ul>
                </div>
            </div>

            <!-- METC Requirements -->
            <div class="bg-white/90 backdrop-blur-sm rounded-2xl p-6 lg:p-8 border border-slate-200 hover:border-purple-400 transition-colors shadow-lg hover:shadow-xl relative overflow-hidden group">
                <div class="absolute inset-0 bg-gradient-to-r from-transparent via-purple-50/50 to-transparent translate-x-[-100%] group-hover:translate-x-[100%] transition-transform duration-700 z-0"></div>
                <div class="relative z-10">
                    <h3 class="text-2xl font-bold text-purple-700 mb-6 border-b border-slate-100 pb-4">METC</h3>
                <ul class="space-y-4">
                    <li class="flex items-start gap-3">
                        <svg class="w-6 h-6 text-green-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                        <span class="text-slate-700">Warga Negara Indonesia (WNI)</span>
                    </li>
                    <li class="flex items-start gap-3">
                        <svg class="w-6 h-6 text-green-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                        <span class="text-slate-700">Terbuka untuk Tech Professional, Mahasiswa, atau Talenta Digital</span>
                    </li>
                    <li class="flex items-start gap-3">
                        <svg class="w-6 h-6 text-green-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                        <span class="text-slate-700">Memiliki ketertarikan kuat pada teknologi ekosistem Microsoft</span>
                    </li>
                    <li class="flex items-start gap-3">
                        <svg class="w-6 h-6 text-green-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                        <span class="text-slate-700">Memiliki akses ke laptop/komputer dan jaringan internet stabil</span>
                    </li>
                    <li class="flex items-start gap-3">
                        <svg class="w-6 h-6 text-green-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                        <span class="text-slate-700">Mematuhi tata tertib kegiatan dan workshop yang diselenggarakan</span>
                    </li>
                </ul>
                </div>
            </div>
        </div>
    </div>
</section>
