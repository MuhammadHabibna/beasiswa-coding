---
---

<section id="requirements" class="bg-white py-20 px-4">
    <div class="max-w-screen-xl mx-auto fade-in-up">
        <div class="text-center mb-12">
            <h2 class="text-3xl font-extrabold text-slate-800 mb-4">Syarat Pendaftaran</h2>
            <p class="text-slate-600">Pastikan Anda memenuhi kriteria berikut sebelum mendaftar program.</p>
        </div>

        <div class="grid md:grid-cols-2 gap-8">
            <!-- Coding Camp Requirements -->
            <div class="bg-slate-50 rounded-2xl p-6 lg:p-8 border border-slate-200 hover:border-blue-300 transition-colors hover:shadow-lg">
                <h3 class="text-2xl font-bold text-blue-700 mb-6 border-b border-slate-200 pb-4">Coding Camp 2.0</h3>
                <ul class="space-y-4">
                    <li class="flex items-start gap-3">
                        <svg class="w-6 h-6 text-green-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                        <span class="text-slate-700">Warga Negara Indonesia (WNI)</span>
                    </li>
                    <li class="flex items-start gap-3">
                        <svg class="w-6 h-6 text-green-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                        <span class="text-slate-700">Terbuka untuk umum</span>
                    </li>
                    <li class="flex items-start gap-3">
                        <svg class="w-6 h-6 text-green-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                        <span class="text-slate-700">Berkomitmen mengikuti program hingga akhir</span>
                    </li>
                    <li class="flex items-start gap-3">
                        <svg class="w-6 h-6 text-green-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                        <span class="text-slate-700">Memiliki laptop atau komputer, serta memiliki jaringan internet</span>
                    </li>
                    <li class="flex items-start gap-3">
                        <svg class="w-6 h-6 text-green-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                        <span class="text-slate-700">Belum pernah mendaftar program Coding Camp 2025 atau Coding Camp 2026 1.0</span>
                    </li>
                </ul>
            </div>

            <!-- METC Requirements -->
            <div class="bg-slate-50 rounded-2xl p-6 lg:p-8 border border-slate-200 hover:border-purple-300 transition-colors hover:shadow-lg">
                <h3 class="text-2xl font-bold text-purple-700 mb-6 border-b border-slate-200 pb-4">METC</h3>
                <ul class="space-y-4">
                    <li class="flex items-start gap-3">
                        <svg class="w-6 h-6 text-green-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                        <span class="text-slate-700">Warga Negara Indonesia (WNI)</span>
                    </li>
                    <li class="flex items-start gap-3">
                        <svg class="w-6 h-6 text-green-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                        <span class="text-slate-700">Terbuka untuk Tech Professional, Mahasiswa, atau Talenta Digital</span>
                    </li>
                    <li class="flex items-start gap-3">
                        <svg class="w-6 h-6 text-green-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                        <span class="text-slate-700">Memiliki ketertarikan kuat pada teknologi ekosistem Microsoft</span>
                    </li>
                    <li class="flex items-start gap-3">
                        <svg class="w-6 h-6 text-green-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                        <span class="text-slate-700">Memiliki akses ke laptop/komputer dan jaringan internet stabil</span>
                    </li>
                    <li class="flex items-start gap-3">
                        <svg class="w-6 h-6 text-green-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                        <span class="text-slate-700">Mematuhi tata tertib kegiatan dan workshop yang diselenggarakan</span>
                    </li>
                </ul>
            </div>
        </div>
    </div>
</section>
