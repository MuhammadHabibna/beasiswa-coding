---
interface Props {
  title: string;
  subtitle: string;
  description: string;
  tags: string[];
  features: string[];
  ctaLink: string;
  detailsLink: string;
  primaryColor: 'blue' | 'purple';
  image: string;
  deadline: string;
}

const { title, subtitle, description, tags, features, ctaLink, primaryColor, image, deadline } = Astro.props;

const bgClass = 'bg-surface border-subtle-light hover:border-slate-300';
const btnClass = primaryColor === 'blue' 
    ? 'bg-primary hover:bg-primary-dark focus:ring-primary/40 shadow-premium hover:shadow-glow text-white' 
    : 'bg-secondary hover:bg-purple-600 focus:ring-secondary/40 shadow-premium hover:shadow-glow-accent text-white';
const tagClass = primaryColor === 'blue' 
    ? 'bg-blue-50 text-blue-700 border-blue-200' 
    : 'bg-purple-50 text-purple-700 border-purple-200';
---

<div class={`flex flex-col p-0 mx-auto max-w-lg text-center rounded-2xl border shadow-sm ${bgClass} overflow-hidden group hover:shadow-hover-premium transition-all duration-300 hover:-translate-y-2 relative bg-white`}>
    <div class="relative h-48 w-full overflow-hidden bg-slate-100">
        <img src={image} alt={title} class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" />
        <div class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
        <div class="absolute top-4 right-4 bg-rose-500/90 backdrop-blur-sm text-white text-xs font-bold px-3 py-1.5 rounded-full shadow-lg border border-white/20">
            Deadline: {deadline}
        </div>
    </div>
    
    <div class="p-8 flex flex-col flex-grow relative bg-white">
        <h3 class="mb-2 text-2xl font-bold text-slate-800 tracking-tight">{title}</h3>
        <p class="font-bold text-primary mb-5 text-xs uppercase tracking-widest">{subtitle}</p>
    
    <div class="flex justify-center gap-2 mb-6">
        {tags.map((tag) => (
            <span class={`text-[11px] font-semibold px-3 py-1 rounded-full border ${tagClass} uppercase tracking-wider`}>
                {tag}
            </span>
        ))}
    </div>

    <p class="mb-8 font-normal text-subtle text-base leading-relaxed">
        {description}
    </p>

    <ul role="list" class="mb-10 space-y-4 text-left">
        {features.map((feature) => (
            <li class="flex items-center space-x-4">
                <div class="flex-shrink-0 w-6 h-6 rounded-full bg-emerald-50 flex items-center justify-center border border-emerald-100">
                    <svg class="w-4 h-4 text-emerald-500" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path></svg>
                </div>
                <span class="text-slate-600 font-medium text-sm">{feature}</span>
            </li>
        ))}
    </ul>
    
    <div class="mt-auto relative z-10">
        <a href={ctaLink} target="_blank" rel="noopener noreferrer" class={`relative overflow-hidden inline-flex items-center justify-center focus:ring-4 focus:outline-none font-bold rounded-xl text-sm px-5 py-3.5 text-center w-full transition-all duration-300 ${btnClass}`}>
            <span class="absolute inset-0 w-full h-full bg-gradient-to-r from-transparent via-white/20 to-transparent -translate-x-full hover:animate-[shimmer_1.5s_infinite]"></span>
            <span class="relative z-10">Daftar Sekarang</span>
        </a>
    </div>
    </div>
</div>
