---
interface Props {
  title: string;
  subtitle: string;
  description: string;
  tags: string[];
  features: string[];
  ctaLink: string;
  detailsLink: string;
  primaryColor: 'blue' | 'purple';
  image: string;
  deadline: string;
}

const { title, subtitle, description, tags, features, ctaLink, primaryColor, image, deadline } = Astro.props;

const bgClass = 'bg-surface border-subtle-light hover:border-slate-300';
const btnClass = primaryColor === 'blue' 
    ? 'bg-gradient-to-r from-blue-600 to-blue-500 hover:from-blue-700 hover:to-blue-600 focus:ring-blue-500/40 shadow-[0_4px_14px_0_rgb(37,99,235,0.39)] hover:shadow-[0_6px_20px_rgba(37,99,235,0.23)] text-white' 
    : 'bg-gradient-to-r from-purple-600 to-indigo-600 hover:from-purple-700 hover:to-indigo-700 focus:ring-purple-500/40 shadow-[0_4px_14px_0_rgb(147,51,234,0.39)] hover:shadow-[0_6px_20px_rgba(147,51,234,0.23)] text-white';
const tagClass = primaryColor === 'blue' 
    ? 'bg-blue-50 text-blue-700 border-blue-200' 
    : 'bg-purple-50 text-purple-700 border-purple-200';
---

<div class={`flex flex-col p-0 mx-auto w-full max-w-lg text-center rounded-2xl border shadow-sm ${bgClass} overflow-hidden group hover:shadow-hover-premium transition-all duration-300 hover:-translate-y-2 relative bg-white`}>
    <div class="relative h-40 sm:h-48 w-full overflow-hidden bg-slate-100">
        <img src={image} alt={title} class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" />
        <div class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
        <div class="absolute top-3 right-3 sm:top-4 sm:right-4 bg-rose-500/90 backdrop-blur-sm text-white text-[10px] sm:text-xs font-bold px-2.5 py-1 sm:px-3 sm:py-1.5 rounded-full shadow-lg border border-white/20">
            Deadline: {deadline}
        </div>
    </div>
    
    <div class="p-6 sm:p-8 flex flex-col flex-grow relative bg-white">
        <h3 class="mb-1.5 sm:mb-2 text-xl sm:text-2xl font-bold text-slate-800 tracking-tight">{title}</h3>
        <p class="font-bold text-primary mb-4 sm:mb-5 text-[10px] sm:text-xs uppercase tracking-widest">{subtitle}</p>
    
    <div class="flex flex-wrap justify-center gap-1.5 sm:gap-2 mb-5 sm:mb-6">
        {tags.map((tag) => (
            <span class={`text-[10px] sm:text-[11px] font-semibold px-2.5 py-0.5 sm:px-3 sm:py-1 rounded-full border ${tagClass} uppercase tracking-wider`}>
                {tag}
            </span>
        ))}
    </div>

    <p class="mb-6 sm:mb-8 font-normal text-subtle text-sm sm:text-base leading-relaxed">
        {description}
    </p>

    <ul role="list" class="mb-8 sm:mb-10 space-y-3 sm:space-y-4 text-left">
        {features.map((feature) => (
            <li class="flex items-center space-x-3 sm:space-x-4">
                <div class="flex-shrink-0 w-5 h-5 sm:w-6 sm:h-6 rounded-full bg-emerald-50 flex items-center justify-center border border-emerald-100">
                    <svg class="w-3 h-3 sm:w-4 sm:h-4 text-emerald-500" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path></svg>
                </div>
                <span class="text-slate-600 font-medium text-xs sm:text-sm">{feature}</span>
            </li>
        ))}
    </ul>
    
    <div class="mt-auto relative z-10">
        <a href={ctaLink} target="_blank" rel="noopener noreferrer" class={`relative overflow-hidden inline-flex items-center justify-center focus:ring-4 focus:outline-none font-bold rounded-xl text-sm sm:text-base px-5 py-3.5 sm:px-6 sm:py-4 text-center w-full transition-all duration-300 transform hover:-translate-y-1 group ${btnClass}`}>
            <span class="absolute inset-0 w-full h-full bg-gradient-to-r from-transparent via-white/30 to-transparent -translate-x-[150%] group-hover:translate-x-[150%] transition-transform duration-700 ease-out z-0"></span>
            
            <span class="relative z-10 flex items-center gap-1.5 sm:gap-2">
                Daftar Sekarang
                <svg class="w-4 h-4 sm:w-5 sm:h-5 transition-transform duration-300 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
                </svg>
            </span>
        </a>
    </div>
    </div>
</div>
